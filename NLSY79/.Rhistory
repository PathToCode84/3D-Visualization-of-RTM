# If there are values not categorized they will be represented as NA
vallabels = function(data) {
data$C0005400 <- factor(data$C0005400,
levels=c(1.0,2.0),
labels=c("MALE",
"FEMALE")
)
data$Y2267000 <- factor(data$Y2267000,
levels=c(532.0),
labels=c("532")
)
return(data)
}
