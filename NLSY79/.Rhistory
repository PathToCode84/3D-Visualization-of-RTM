# Use qnames rather than rnums
qnames = function(data) {
names(data) <- c("CPUBID_XRND",
"MPUBID_XRND",
"CSEX_XRND",
"CYRB_XRND",
"CSAGE2008_2008",
"MS-HLTH-HGT-TOTALINCHES_2008",
"MS-HLTH-WGT-LBSONLY_2008",
"CSAGE2010_2010",
"HLTH-HGT-TOTALINCHES_2010",
"HLTH-WGT-LBSONLY_2010",
"CSAGE2012_2012",
"HLTH-HGT-TOTALINCHES_2012",
"HLTH-WGT-LBSONLY_2012",
"VERSION_R29_XRND")
return(data)
}
